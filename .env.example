# ============================================================================
# ExtraSpace LP environment example
# Copy to .env (or .env.production) and fill in real values.
# ============================================================================

# Backend API base URL (override per env). Default points to api.extraspace.kz.
# VITE_API_URL=https://api.extraspace.kz

# 2GIS Maps API key (optional, used for branches map on / and /lp/* pages)
# VITE_2GIS_API_KEY=

# Google Tag Manager container ID — required for LP analytics (events from
# src/shared/lib/analytics.js). When empty, GTM is NOT injected and dataLayer
# pushes are still made (useful in dev / preview).
# Format: GTM-XXXXXXX
VITE_GTM_ID=

# Optional dedicated lead endpoint for LP forms. When set, LP forms POST to
# this URL directly instead of falling back to the existing /submit-lead route
# from the main site backend (used by src/shared/lib/submitLead.js).
# Example: VITE_LEAD_ENDPOINT=https://api.extraspace.kz/api/lp-leads
# VITE_LEAD_ENDPOINT=

# Telegram channel link used in CallbackRequestModal — already supported by
# the main site, kept here for completeness.
# VITE_TELEGRAM_URL=https://t.me/extraspacekz
